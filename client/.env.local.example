# ── Single Next.js deployment (client + API routes in one app) ────────────────
# Copy this file to .env.local for local development.
# For Vercel production: add the vars in the two sections below (NEXT_PUBLIC_API_URL
# and Server-side) in Project Settings → Environment Variables. Skip the last
# section — see its own note.

# ── Client (NEXT_PUBLIC_*) ────────────────────────────────────────────────────
# Leave empty — API is same-origin (/api/...). Only set this if running the
# client against a separate Express dev server (e.g. NEXT_PUBLIC_API_URL=http://localhost:5000).
NEXT_PUBLIC_API_URL=

# ── Server-side (used by Next.js API route handlers) ─────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/fms?retryWrites=true&w=majority

# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── NOT read by this app — reference only ─────────────────────────────────────
# Everything below is read exclusively by server/src/seed.ts, a one-off script
# you run locally (see server/.env.example) to populate MongoDB. The deployed
# Next.js app never reads these — do NOT add them to Vercel project settings.
# Listed here only so you know they exist and where to set them for seeding.
#
# SEED_ADMIN_USERNAME, SEED_ADMIN_PASSWORD, and every SALARY_* faculty-contract
# variable — see server/.env.example for the full, current list.
