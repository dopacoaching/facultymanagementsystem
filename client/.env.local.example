# ── Single Next.js deployment (client + API routes in one app) ────────────────
# Copy this file to .env.local for local development.
# For Vercel production: add every var below in Project Settings → Environment Variables.

# ── Client (NEXT_PUBLIC_*) ────────────────────────────────────────────────────
# Leave empty — API is same-origin (/api/...). Only set this if running the
# client against a separate Express dev server (e.g. NEXT_PUBLIC_API_URL=http://localhost:5000).
NEXT_PUBLIC_API_URL=

# ── Server-side (used by Next.js API route handlers) ─────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/fms?retryWrites=true&w=majority

# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Seed credentials ──────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=it@dopacoaching.com
SEED_ADMIN_PASSWORD=

# ── Faculty salary contracts ──────────────────────────────────────────────────
SALARY_ASHRAF_FIXED=
SALARY_ASHRAF_QUOTA_HRS=
SALARY_ADIL_RATE=
SALARY_SANOOP_RATE=
SALARY_FAHAD_FIXED=
SALARY_FAHAD_MIN_DAYS=
SALARY_ASHIQUE_FIXED=
SALARY_ASHIQUE_MONTHLY_LEAVE=
SALARY_ASHIQUE_APRIL_LEAVE=
SALARY_HISHAM_RATE=
SALARY_MUNEEB_RATE=
SALARY_MUNEEB_MIN_DAYS=
SALARY_MUNEEB_MIN_DAYS_DRY=
SALARY_FAHIM_FIXED=
SALARY_FAHIM_OT_THRESHOLD=
SALARY_FAHIM_OT_RATE=
SALARY_MUHSIN_RATE=
SALARY_ANAND_FIXED=
SALARY_ANAND_QUOTA_HRS=
SALARY_HABID_RATE=
SALARY_SHIBLI_FIXED_COMP=
SALARY_SHIBLI_VAR_COMP=
SALARY_SHIBLI_CANCEL_PENALTY=
SALARY_SHIBLI_MIN_DAYS=
SALARY_SHIBLI_MIN_HOURS=
SALARY_ANOOP_FIXED=
SALARY_ANOOP_MIN_DAYS=
