# ── Client environment variables ─────────────────────────────────────────────
# Copy this file to .env.local for local development.
# For Netlify: set these in Site Settings → Environment Variables.

# URL of the deployed Express API server.
# Local dev:   http://localhost:5000
# Production:  https://your-api.onrender.com  (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Coordinator access token — the /c/[token] URL segment.
# Use a long, hard-to-guess random string (e.g. openssl rand -hex 24).
# Share the full URL with coordinators only. NEVER use a short or guessable value.
NEXT_PUBLIC_COORDINATOR_TOKEN=
