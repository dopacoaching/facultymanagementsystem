{
  "name": "dopa-fms-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts --ext ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx --env-file=../.env src/seed.ts",
    "seed:syllabus": "tsx --env-file=../.env src/scripts/seed-syllabus.ts",
    "seed:ig-curriculum": "tsx --env-file=../.env src/scripts/seed-ig-curriculum.ts",
    "seed:ig-neet-jee": "tsx --env-file=../.env src/scripts/seed-ig-neet-jee.ts",
    "set-ig-stream": "tsx --env-file=../.env src/scripts/set-ig-batch-stream.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.6",
    "@vercel/node": "^5.1.16",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
