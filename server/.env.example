# ── Server environment variables ─────────────────────────────────────────────
# Copy this file to .env for local development.
# For Render: add each variable in Dashboard → Environment.
# NEVER commit real values.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dopa_fms?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_STRING_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=5000

# Your Netlify site URL (no trailing slash). Required in production.
CLIENT_URL=https://your-site.netlify.app

NODE_ENV=production

# ── Seed credentials (run npm run seed once after deploy) ────────────────────
# Usernames
SEED_ADMIN_USERNAME=
SEED_HR_USERNAME=
SEED_REPEATERS_USERNAME=
SEED_IS_ACADEMIC_USERNAME=
# Passwords — MUST meet complexity: 8-64 chars, uppercase, lowercase, digit, special char (!@#$%^&* etc.)
SEED_ADMIN_PASSWORD=
SEED_MGMT_PASSWORD=
SEED_FACULTY_PASSWORD=

# ── Faculty salary contracts ──────────────────────────────────────────────────
SALARY_ASHRAF_FIXED=
SALARY_ASHRAF_QUOTA_HRS=
SALARY_ADIL_RATE=
SALARY_SANOOP_RATE=
SALARY_FAHAD_FIXED=
SALARY_FAHAD_MIN_DAYS=
SALARY_ASHIQUE_FIXED=
SALARY_ASHIQUE_MONTHLY_LEAVE=
SALARY_ASHIQUE_APRIL_LEAVE=
SALARY_HISHAM_RATE=
SALARY_MUNEEB_RATE=
SALARY_MUNEEB_MIN_DAYS=
SALARY_MUNEEB_MIN_DAYS_DRY=
SALARY_FAHIM_FIXED=
SALARY_FAHIM_OT_THRESHOLD=
SALARY_FAHIM_OT_RATE=
SALARY_MUHSIN_RATE=
SALARY_ANAND_FIXED=
SALARY_ANAND_QUOTA_HRS=
SALARY_HABID_RATE=
SALARY_SHIBLI_FIXED_COMP=
