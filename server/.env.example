# ── Server environment variables (local-dev-only Express mirror) ────────────
# server/ is never deployed — production runs entirely out of client/ on
# Vercel (see client/.env.local.example). This file is only for running the
# Express server locally per README.md's "Option B — dual backend" workflow.
# NEVER commit real values.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dopa_fms?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_STRING_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=5000

# Origin of the Next.js client you're running against (no trailing slash).
CLIENT_URL=http://localhost:3000

NODE_ENV=development

# ── Seed credentials (run npm run seed once after connecting to a fresh DB) ──
# Usernames
SEED_ADMIN_USERNAME=
SEED_HR_USERNAME=
SEED_REPEATERS_USERNAME=
SEED_IS_ACADEMIC_USERNAME=
# Passwords — MUST meet complexity: 8-64 chars, uppercase, lowercase, digit, special char (!@#$%^&* etc.)
SEED_ADMIN_PASSWORD=
SEED_MGMT_PASSWORD=
SEED_FACULTY_PASSWORD=

